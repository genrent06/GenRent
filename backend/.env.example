# ── App ──────────────────────────────────────────────
ENV=production
APP_PORT=8080

# MUST be changed — 32+ random characters
JWT_SECRET=replace-with-a-strong-random-secret

# Comma-separated allowed origins (no trailing slash)
ALLOWED_ORIGINS=https://genrent.in,https://www.genrent.in

# ── Database ─────────────────────────────────────────
DB_USER=genrent
DB_PASSWORD=replace-with-strong-db-password
DB_NAME=genrent

# ── Email (Gmail SMTP) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your@gmail.com
SMTP_FROM_NAME=GenRent

# ── Domain ───────────────────────────────────────────
# Used by Caddy for automatic TLS — must point to this server's IP
DOMAIN=genrent.in
