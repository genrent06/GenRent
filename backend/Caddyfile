# Replace genrent.in with your actual domain.
# Caddy automatically obtains and renews TLS certificates from Let's Encrypt.
{$DOMAIN:genrent.in} {
    # Reverse proxy all traffic to the Go app
    reverse_proxy app:8080

    # Compress responses
    encode gzip

    # Security headers (supplement what the Go middleware already sets)
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        -Server  # hide Caddy version
    }

    # Access log
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}

# Redirect bare HTTP → HTTPS (Caddy handles this automatically, but explicit is clearer)
http://{$DOMAIN:genrent.in} {
    redir https://{host}{uri} permanent
}
